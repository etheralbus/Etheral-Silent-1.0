-- Update slider
local function UpdateSlider(frame, input)
    local track = frame.Track
    local absoluteSize = track.AbsoluteSize.X
    local mouseX = input.Position.X - track.AbsolutePosition.X
    
    local percent = math.clamp(mouseX / absoluteSize, 0, 1)
    local value = math.round(percent * 100) / 100
    value = math.max(value, 0.05)
    
    frame.Value = value
    frame.Fill.Size = UDim2.new(percent, 0, 1, 0)
    frame.Handle.Position = UDim2.new(percent, -6, 0.5, -6)
    frame.ValueLabel.Text = string.format("%.2f", value)
    
    smoothingValue = value
    CONFIG.LockStrength = value
end

-- Toggle option
local function ToggleOption(id, frame)
    local newState = not frame.Enabled
    frame.Enabled = newState
    
    if newState then
        frame.Toggle.BorderColor3 = Color3.fromRGB(200, 140, 230)
        frame.InnerGlow.BackgroundTransparency = 0.2
    else
        frame.Toggle.BorderColor3 = Color3.fromRGB(80, 80, 90)
        frame.InnerGlow.BackgroundTransparency = 1
    end
    
    if id == "esp" then
        espEnabled = newState
        if newState then
            EnableESP()
        else
            DisableESP()
        end
    elseif id == "hitbox" then
        hitboxesEnabled = newState
        if newState then
            EnableHitboxes()
        else
            DisableHitboxes()
        end
    elseif id == "fov" then
        fovEnabled = newState
        fovData.FOVFrame.Visible = newState
        if not newState then
            isActive = false
            UpdateStatus("○ FOV OFF")
        else
            UpdateStatus("○ READY")
        end
    end
end

-- ESP Functions
local espLines = {}

local function EnableESP()
    DisableESP()
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= Player and player.Character then
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                local line = Instance.new("Frame")
                line.Name = "ESPLine_" .. player.Name
                line.Size = UDim2.new(0, 2, 0, 2)
                line.BackgroundColor3 = Color3.fromRGB(200, 140, 230)
                line.BackgroundTransparency = 0.3
                line.BorderSizePixel = 0
                line.Parent = fovData.ScreenGui
                
                local corner = Instance.new("UICorner")
                corner.CornerRadius = UDim.new(1, 0)
                corner.Parent = line
                
                table.insert(espLines, {
                    Player = player,
                    Line = line,
                    Root = root
                })
            end
        end
    end
end

local function DisableESP()
    for _, data in pairs(espLines) do
        if data.Line then
            data.Line:Destroy()
        end
    end
    espLines = {}
end

-- Hitbox Functions
local hitboxParts = {}

local function EnableHitboxes()
    DisableHitboxes()
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= Player and player.Character then
            local char = player.Character
            local head = char and char:FindFirstChild("Head")
            
            if head then
                local box = Instance.new("BoxHandleAdornment")
                box.Name = "Hitbox_" .. player.Name
                box.Size = Vector3.new(1.8, 1.8, 1.8)
                box.Adornee = head
                box.Color3 = Color3.fromRGB(200, 140, 230)
                box.Transparency = 0.5
                box.ZIndex = 0
                box.Visible = true
                box.Parent = head
                
                table.insert(hitboxParts, box)
            end
        end
    end
end

local function DisableHitboxes()
    for _, box in pairs(hitboxParts) do
        if box and box.Parent then
            box:Destroy()
        end
    end
    hitboxParts = {}
end

