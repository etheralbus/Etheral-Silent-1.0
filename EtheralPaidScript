end

-- ===== HUD functions =====
local hideTimer = nil

local function ShowHUD(value)
    hudSizeLabel.Text = tostring(value)
    hudFrame.Visible = true
    hudFrame.Position = UDim2.new(0.5, -70, -0.12, 0)
    for i = 1, 10 do
        local progress = i / 10
        local y = -0.12 + (0.05 - (-0.12)) * progress
        hudFrame.Position = UDim2.new(0.5, -70, y, 0)
        task.wait(0.03)
    end
    if hideTimer then
        task.cancel(hideTimer)
        hideTimer = nil
    end
    hideTimer = task.delay(CONFIG.HUDAutoHideDelay, function()
        for i = 1, 10 do
            local progress = i / 10
            local y = 0.05 - (0.05 - (-0.12)) * progress
            hudFrame.Position = UDim2.new(0.5, -70, y, 0)
            task.wait(0.03)
        end
        hudFrame.Visible = false
        hideTimer = nil
    end)
end

