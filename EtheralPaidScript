-- Create BodyGyro
local function SetupGyro()
    local char = Player.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local gyro = Instance.new("BodyGyro")
    gyro.Parent = hrp
    gyro.MaxTorque = Vector3.new(4000, 4000, 4000)
    gyro.CFrame = hrp.CFrame
    return gyro
end

local gyro = SetupGyro()
print("Gyro:", gyro)

-- Simple aimlock: when X pressed, rotate gyro to nearest player
local isActive = false
UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.X then
        isActive = not isActive
        print("Toggled:", isActive)
    end
end)

-- Helper to get mouse position
local function GetMousePos()
    -- Use UserInputService if Mouse is nil
    local success, pos = pcall(function()
        return UserInputService:GetMouseLocation()
    end)
    if success then
        return pos.X, pos.Y
    else
        -- fallback to Mouse
        local mouse = Player:GetMouse()
        if mouse then
            return mouse.X, mouse.Y
        else
            return 0, 0
        end
    end
end

RunService.RenderStepped:Connect(function()
    if not isActive or not gyro or not gyro.Parent then
        if isActive and not gyro then
            gyro = SetupGyro()
            print("Recreating gyro")
        end
        return
    end

    local mouseX, mouseY = GetMousePos()
    -- Find nearest player in FOV (90px)
    local nearest = nil
    local nearestDist = 90
    local center = Vector2.new(mouseX, mouseY)

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player and p.Character then
            local head = p.Character:FindFirstChild("Head")
            if head then
                local pos, onScreen = Camera:WorldToScreenPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = p
                    end
                end
            end
        end
    end

    if nearest and nearest.Character then
        local head = nearest.Character:FindFirstChild("Head")
        if head then
            local hrp = gyro.Parent
            local lookAt = CFrame.lookAt(hrp.Position, head.Position)
            gyro.CFrame = gyro.CFrame:Lerp(lookAt, 0.5)
            print("Aiming at:", nearest.Name)
        end
    end
end)

