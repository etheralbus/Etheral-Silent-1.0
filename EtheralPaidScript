    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 16)
    corner.Parent = panel
    
    local border = Instance.new("Frame")
    border.Size = UDim2.new(1, 0, 1, 0)
    border.BackgroundTransparency = 1
    border.BorderSizePixel = 1
    border.BorderColor3 = Color3.fromRGB(80, 80, 100)
    border.Parent = panel
    
    local borderCorner = Instance.new("UICorner")
    borderCorner.CornerRadius = UDim.new(0, 16)
    borderCorner.Parent = border
    
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 40)
    title.Position = UDim2.new(0, 0, 0, 0)
    title.BackgroundTransparency = 1
    title.Text = "⚙ SETTINGS"
    title.TextColor3 = Color3.fromRGB(200, 140, 230)
    title.TextSize = 18
    title.Font = Enum.Font.SourceSansSemibold
    title.Parent = panel
    
    local function AddToggle(yPos, labelText, stateGetter, stateSetter)
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(0.9, 0, 0, 45)
        frame.Position = UDim2.new(0.05, 0, 0, yPos)
        frame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
        frame.BackgroundTransparency = 0.5
        frame.BorderSizePixel = 0
        frame.Parent = panel
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 8)
        corner.Parent = frame
        
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0.65, 0, 1, 0)
        label.Position = UDim2.new(0, 12, 0, 0)
        label.BackgroundTransparency = 1
        label.Text = labelText
        label.TextColor3 = Color3.fromRGB(200, 200, 210)
        label.TextSize = 14
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Font = Enum.Font.SourceSansSemibold
        label.Parent = frame
        
        local toggle = Instance.new("Frame")
        toggle.Size = UDim2.new(0, 28, 0, 28)
        toggle.Position = UDim2.new(0.85, -14, 0.5, -14)
        toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
        toggle.BackgroundTransparency = 0.3
        toggle.BorderSizePixel = 1
        toggle.BorderColor3 = Color3.fromRGB(80, 80, 90)
        toggle.Parent = frame
        
        local toggleCorner = Instance.new("UICorner")
        toggleCorner.CornerRadius = UDim.new(0, 6)
        toggleCorner.Parent = toggle
        
        local innerGlow = Instance.new("Frame")
        innerGlow.Size = UDim2.new(0.6, 0, 0.6, 0)
        innerGlow.Position = UDim2.new(0.2, 0, 0.2, 0)
        innerGlow.BackgroundColor3 = Color3.fromRGB(200, 140, 230)
        innerGlow.BackgroundTransparency = 1
        innerGlow.BorderSizePixel = 0
        innerGlow.Parent = toggle
        
        local innerCorner = Instance.new("UICorner")
        innerCorner.CornerRadius = UDim.new(0, 4)
        innerCorner.Parent = innerGlow
        
        local function updateToggle()
            if stateGetter() then
                toggle.BorderColor3 = Color3.fromRGB(200, 140, 230)
                innerGlow.BackgroundTransparency = 0.2
            else
                toggle.BorderColor3 = Color3.fromRGB(80, 80, 90)
                innerGlow.BackgroundTransparency = 1
            end
        end
        updateToggle()
        
        frame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                stateSetter(not stateGetter())
                updateToggle()
            end
        end)
        toggle.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                stateSetter(not stateGetter())
                updateToggle()
            end
        end)
    end
    
    AddToggle(50, "ESP Lines", function() return espEnabled end, function(v) espEnabled = v end)
    AddToggle(110, "Hitboxes", function() return hitboxesEnabled end, function(v) hitboxesEnabled = v end)
    AddToggle(170, "FOV Circle", function() return fovEnabled end, function(v) 
        fovEnabled = v
        fovFrame.Visible = v
        if not v then isActive = false end
    end)
    
    return panel
end

local settingsPanel = CreateSettingsPanel()
