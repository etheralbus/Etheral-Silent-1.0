-- BODYGYRO AIMLOCK (Undetectable)
local plr = game.Players.LocalPlayer
local mouse = plr:GetMouse()
local cam = workspace.CurrentCamera

local function GetClosestTarget()
    local nearest = nil
    local nearestDist = 90
    local center = Vector2.new(mouse.X, mouse.Y)
    
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= plr and p.Character then
            local head = p.Character:FindFirstChild("Head")
            if head then
                local pos, onScreen = cam:WorldToScreenPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = p
                    end
                end
            end
        end
    end
    return nearest
end

-- Create BodyGyro in character
plr.CharacterAdded:Connect(function(char)
    wait(0.5)
    local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("HumanoidRootPart")
    if torso then
        local gyro = Instance.new("BodyGyro")
        gyro.Parent = torso
        gyro.MaxTorque = Vector3.new(4000, 4000, 4000)
        gyro.D = 50
        gyro.P = 5000
        gyro.CFrame = torso.CFrame
        gyro.Name = "AimGyro"
        
        -- Update gyro every frame
        game:GetService("RunService").RenderStepped:Connect(function()
            if mouse.Button1Down then
                local target = GetClosestTarget()
                if target and target.Character then
                    local head = target.Character:FindFirstChild("Head")
                    if head then
                        local lookAt = CFrame.lookAt(torso.Position, head.Position)
                        gyro.CFrame = lookAt
                    end
                end
            end
        end)
    end
end)

print("BodyGyro aimlock loaded")
