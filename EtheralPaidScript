-- Silent Aim - With Error Display
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera

local Player = Players.LocalPlayer
local Mouse = Player:GetMouse()

local FOVRadius = 90
local LockStrength = 0.35
local MaxTorque = 600
local MaxDistance = 200
local RotationSpeed = 180

local isActive = false
local currentTarget = nil
local gyro = nil
local torso = nil

local PlayerGui = Player:WaitForChild("PlayerGui", 3)
if not PlayerGui then return end

local screenGui = Instance.new("ScreenGui")
screenGui.Parent = PlayerGui

local fovFrame = Instance.new("Frame")
fovFrame.Size = UDim2.new(0, FOVRadius * 2, 0, FOVRadius * 2)
fovFrame.Position = UDim2.new(0, 0, 0, 0)
fovFrame.BackgroundTransparency = 1
fovFrame.Parent = screenGui

local circleContainer = Instance.new("Frame")
circleContainer.Size = UDim2.new(1, 0, 1, 0)
circleContainer.Position = UDim2.new(0, 0, 0, 0)
circleContainer.BackgroundTransparency = 1
circleContainer.Parent = fovFrame

local dashParts = {}
local function BuildDashes()
    for _, child in pairs(circleContainer:GetChildren()) do child:Destroy() end
    dashParts = {}
    local numDashes = math.floor((2 * math.pi * FOVRadius) / (8 + 12))
    local angleStep = (2 * math.pi) / numDashes
    for i = 1, numDashes do
        local angle = i * angleStep
        local x = FOVRadius * math.cos(angle)
        local y = FOVRadius * math.sin(angle)
        local dash = Instance.new("Frame")
        dash.Size = UDim2.new(0, 8, 0, 2)
        dash.Position = UDim2.new(0.5, x - 4, 0.5, y - 1)
        dash.BackgroundColor3 = Color3.fromRGB(220, 160, 255)
        dash.BackgroundTransparency = 0
        dash.BorderSizePixel = 0
        dash.Rotation = math.deg(angle)
        dash.Parent = circleContainer
        table.insert(dashParts, { Frame = dash, Angle = angle })
    end
end
BuildDashes()

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(0, 200, 0, 25)
statusLabel.Position = UDim2.new(0.5, -100, 1.2, 0)
statusLabel.BackgroundTransparency = 1
statusLabel.Text = "Press X"
statusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
statusLabel.TextSize = 13
statusLabel.Font = Enum.Font.SourceSansBold
statusLabel.Parent = fovFrame

-- Rotation
local rotation = 0
RunService.Heartbeat:Connect(function(dt)
    rotation = (rotation + RotationSpeed * dt) % 360
    local angleOffset = math.rad(rotation)
    for _, data in pairs(dashParts) do
        local angle = data.Angle + angleOffset
        local x = FOVRadius * math.cos(angle)
        local y = FOVRadius * math.sin(angle)
        data.Frame.Position = UDim2.new(0.5, x - 4, 0.5, y - 1)
        data.Frame.Rotation = math.deg(angle)
    end
end)

-- Gyro
local function SetupGyro()
    local char = Player.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    if gyro then gyro:Destroy() end
    torso = hrp
    gyro = Instance.new("BodyGyro")
    gyro.Parent = torso
    gyro.MaxTorque = Vector3.new(MaxTorque, MaxTorque, MaxTorque)
    gyro.D = 20
    gyro.P = 2000
    gyro.CFrame = torso.CFrame
    return true
end

Player.CharacterAdded:Connect(function()
    task.wait(0.5)
    SetupGyro()
end)
if Player.Character then SetupGyro() end

-- Target functions
local function IsDowned(character)
    if not character then return true end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return true end
    local state = humanoid:GetState()
    return state == Enum.HumanoidStateType.Physics or
           state == Enum.HumanoidStateType.Dead or
           state == Enum.HumanoidStateType.FallingDown or
           state == Enum.HumanoidStateType.GettingUp
end

local function GetTargets(mousePos)
    local targets = {}
    local camPos = Camera.CFrame.Position
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= Player and player.Character then
            if IsDowned(player.Character) then continue end
            local head = player.Character:FindFirstChild("Head")
            if head then
                local headPos, onScreen = Camera:WorldToScreenPoint(head.Position)
                if onScreen then
                    local distance = (head.Position - camPos).Magnitude
                    if distance <= MaxDistance then
                        table.insert(targets, {
                            Player = player,
                            Head = head,
                            HeadScreenPos = Vector2.new(headPos.X, headPos.Y),
                            Distance = distance,
                            HeadPosition = head.Position,
                        })
                    end
                end
            end
        end
    end
    return targets
end

local function GetBestTarget(targets, mousePos, current)
    local best, bestDist = nil, FOVRadius + 1
    for _, t in pairs(targets) do
        local d = (t.HeadScreenPos - mousePos).Magnitude
        if d <= FOVRadius and d < bestDist then
            bestDist = d
            best = t
        end
    end
    if best and current then
        local currentDist = (current.HeadScreenPos - mousePos).Magnitude
        if bestDist < currentDist - 5 then
            return best
        else
            return current
        end
    end
    return best
end

-- Keybinds
UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.X then
        isActive = not isActive
        statusLabel.Text = isActive and "● ON" or "○ OFF"
        if not isActive then currentTarget = nil
    end

    if input.KeyCode == Enum.KeyCode.F3 then
        FOVRadius = math.min(FOVRadius + 10, 200)
        fovFrame.Size = UDim2.new(0, FOVRadius * 2, 0, FOVRadius * 2)
        BuildDashes()
        statusLabel.Text = "FOV: " .. FOVRadius
        task.delay(1, function()
            statusLabel.Text = isActive and "● ON" or "○ OFF"
        end)
    end

    if input.KeyCode == Enum.KeyCode.F2 then
        FOVRadius = math.max(FOVRadius - 10, 20)
        fovFrame.Size = UDim2.new(0, FOVRadius * 2, 0, FOVRadius * 2)
        BuildDashes()
        statusLabel.Text = "FOV: " .. FOVRadius
        task.delay(1, function()
            statusLabel.Text = isActive and "● ON" or "○ OFF"
        end)
    end
end)

-- Main loop (with error catching)
RunService.RenderStepped:Connect(function()
    -- Get mouse position safely
    local success, mousePos = pcall(function()
        return UserInputService:GetMouseLocation()
    end)
    if not success or not mousePos then
        statusLabel.Text = "Mouse error"
        return
    end
    local mouseX = mousePos.X
    local mouseY = mousePos.Y

    fovFrame.Position = UDim2.new(0, mouseX - FOVRadius, 0, mouseY - FOVRadius)

    if not isActive or not gyro or not torso then
        return
    end

    -- Get targets with error protection
    local targets, err = pcall(GetTargets, Vector2.new(mouseX, mouseY))
    if not targets or #targets == 0 then
        if currentTarget then
            currentTarget = nil
            statusLabel.Text = "○ NO TARGET"
        end
        return
    end

    local target = GetBestTarget(targets, Vector2.new(mouseX, mouseY), currentTarget)
    if target then
        if not currentTarget or target.Player ~= currentTarget.Player then
            currentTarget = target
        end
        local headPos = target.HeadPosition
        local lookAt = CFrame.lookAt(torso.Position, headPos)
        gyro.CFrame = gyro.CFrame:Lerp(lookAt, LockStrength)
        statusLabel.Text = "● " .. target.Player.Name .. " (" .. math.floor(target.Distance) .. "s)"
    else
        if currentTarget then
            currentTarget = nil
            statusLabel.Text = "○ NO TARGET"
        end
    end
end)
