    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.SourceSans
    label.Parent = frame
    
    local toggle = Instance.new("Frame")
    toggle.Size = UDim2.new(0, 22, 0, 22)
    toggle.Position = UDim2.new(0.85, -11, 0.5, -11)
    toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
    toggle.BackgroundTransparency = 0.3
    toggle.BorderSizePixel = 0
    toggle.Parent = frame
    local toggleCorner = Instance.new("UICorner")
    toggleCorner.CornerRadius = UDim.new(0, 4)
    toggleCorner.Parent = toggle
    
    local innerGlow = Instance.new("Frame")
    innerGlow.Size = UDim2.new(0.6, 0, 0.6, 0)
    innerGlow.Position = UDim2.new(0.2, 0, 0.2, 0)
    innerGlow.BackgroundColor3 = Color3.fromRGB(200, 140, 230)
    innerGlow.BackgroundTransparency = 1
    innerGlow.BorderSizePixel = 0
    innerGlow.Parent = toggle
    local innerCorner = Instance.new("UICorner")
    innerCorner.CornerRadius = UDim.new(0, 3)
    innerCorner.Parent = innerGlow
    
    local function update()
        if stateGetter() then
            toggle.BackgroundColor3 = Color3.fromRGB(200, 140, 230)
            toggle.BackgroundTransparency = 0.3
            innerGlow.BackgroundTransparency = 0.2
        else
            toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
            toggle.BackgroundTransparency = 0.3
            innerGlow.BackgroundTransparency = 1
        end
    end
    update()
    
    local function onClick()
        stateSetter(not stateGetter())
        update()
    end
    
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then onClick() end
    end)
    toggle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then onClick() end
    end)
end

