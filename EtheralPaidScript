-- STEALTH AIMLOCK (Bypass detection)
local plr = game.Players.LocalPlayer
local mouse = plr:GetMouse()
local cam = workspace.CurrentCamera

-- Don't change Camera directly – use mouse movement simulation
local function AimAt(target)
    if not target or not target.Character then return end
    local head = target.Character:FindFirstChild("Head")
    if not head then return end
    
    local headPos, onScreen = cam:WorldToScreenPoint(head.Position)
    if not onScreen then return end
    
    -- Simulate mouse movement to head position
    local deltaX = headPos.X - mouse.X
    local deltaY = headPos.Y - mouse.Y
    
    -- Send fake mouse movement (works on some executors)
    mouse.Move(deltaX, deltaY)
    
    -- Alternative: directly set mouse position (if supported)
    mouse.X = headPos.X
    mouse.Y = headPos.Y
end

-- Hook mouse button to aim before shooting
local oldClick = mouse.Button1Down
mouse.Button1Down = function(...)
    -- Find nearest player in FOV (90px)
    local nearest = nil
    local nearestDist = 90
    local center = Vector2.new(mouse.X, mouse.Y)
    
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= plr and p.Character then
            local head = p.Character:FindFirstChild("Head")
            if head then
                local pos, onScreen = cam:WorldToScreenPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = p
                    end
                end
            end
        end
    end
    
    if nearest then
        AimAt(nearest)
    end
    
    -- Call original click
    if oldClick then oldClick(...) end
end

print("Stealth aimlock loaded")
