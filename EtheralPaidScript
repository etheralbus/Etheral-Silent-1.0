    local fovFrame = Instance.new("Frame")
    fovFrame.Name = "FOVFrame"
    fovFrame.Size = UDim2.new(0, CONFIG.FOVRadius * 2, 0, CONFIG.FOVRadius * 2)
    fovFrame.Position = UDim2.new(0, 0, 0, 0)
    fovFrame.BackgroundTransparency = 1
    fovFrame.ClipsDescendants = true
    fovFrame.Parent = screenGui

    local circleContainer = Instance.new("Frame")
    circleContainer.Name = "CircleContainer"
    circleContainer.Size = UDim2.new(1, 0, 1, 0)
    circleContainer.Position = UDim2.new(0, 0, 0, 0)
    circleContainer.BackgroundTransparency = 1
    circleContainer.Parent = fovFrame

    local dashParts = {}
    local function BuildDashes()
        for _, child in pairs(circleContainer:GetChildren()) do child:Destroy() end
        local newParts = {}
        local numDashes = math.floor((2 * math.pi * CONFIG.FOVRadius) / (CONFIG.DashLength + CONFIG.GapLength))
        local angleStep = (2 * math.pi) / numDashes
        for i = 1, numDashes do
            local angle = i * angleStep
            local x = CONFIG.FOVRadius * math.cos(angle)
            local y = CONFIG.FOVRadius * math.sin(angle)
            local dash = Instance.new("Frame")
            dash.Size = UDim2.new(0, CONFIG.DashLength, 0, 2.0)
            dash.Position = UDim2.new(0.5, x - CONFIG.DashLength/2, 0.5, y - 1.0)
            dash.BackgroundColor3 = CONFIG.FOVColor
            dash.BackgroundTransparency = 0
            dash.BorderSizePixel = 0
            dash.Rotation = math.deg(angle)
            dash.Parent = circleContainer
            table.insert(newParts, { Frame = dash, Angle = angle })
        end
        dashParts = newParts
        return newParts
    end
    BuildDashes()

    local statusLabel = Instance.new("TextLabel")
    statusLabel.Size = UDim2.new(0, 280, 0, 25)
    statusLabel.Position = UDim2.new(0.5, -140, 1.2, 0)
    statusLabel.BackgroundTransparency = 1
    statusLabel.Text = "○ READY | FOV: " .. CONFIG.FOVRadius
    statusLabel.TextColor3 = Color3.fromRGB(180, 120, 210)
    statusLabel.TextSize = 13
    statusLabel.Font = Enum.Font.SourceSansBold
    statusLabel.Parent = fovFrame

    return {
        ScreenGui = screenGui,
        FOVFrame = fovFrame,
        CircleContainer = circleContainer,
        DashParts = dashParts,
        StatusLabel = statusLabel,
        HUD = hudFrame,
        Fill = fill,
        Knob = knob,
        Number = number,
        SliderBG = sliderBG,
        BuildDashes = BuildDashes,
        Rotation = 0,
        isHUDVisible = false,
        hideTimer = nil,
    }
end

local fovData = CreateGUI()

local function RebuildFOV()
    fovData.FOVFrame.Size = UDim2.new(0, CONFIG.FOVRadius * 2, 0, CONFIG.FOVRadius * 2)
    fovData.DashParts = fovData.BuildDashes()
    local statusText = fovData.StatusLabel.Text:gsub("FOV: %d+", "FOV: " .. CONFIG.FOVRadius)
    fovData.StatusLabel.Text = statusText
    if fovData.isHUDVisible then
        local percent = (CONFIG.FOVRadius - CONFIG.MinFOV) / (CONFIG.MaxFOV - CONFIG.MinFOV)
        fovData.Fill.Size = UDim2.new(percent, 0, 1, 0)
        fovData.Knob.Position = UDim2.new(percent, 0, 0.5, 0)
        fovData.Number.Text = tostring(CONFIG.FOVRadius)
    end
end

local function UpdateStatus(text)
    fovData.StatusLabel.Text = text .. " | FOV: " .. CONFIG.FOVRadius
end

local function UpdateSlider(percent)
    percent = math.clamp(percent, 0, 1)
    local newFOV = math.round(CONFIG.MinFOV + (CONFIG.MaxFOV - CONFIG.MinFOV) * percent)
    newFOV = math.clamp(newFOV, CONFIG.MinFOV, CONFIG.MaxFOV)
    if newFOV ~= CONFIG.FOVRadius then
        CONFIG.FOVRadius = newFOV
        RebuildFOV()
        fovData.Number.Text = tostring(newFOV)
    end
    fovData.Fill.Size = UDim2.new(percent, 0, 1, 0)
    fovData.Knob.Position = UDim2.new(percent, 0, 0.5, 0)
end

local function ShowHUD()
    if fovData.hideTimer then
        task.cancel(fovData.hideTimer)
        fovData.hideTimer = nil
    end
    if not fovData.isHUDVisible then
        fovData.HUD.Visible = true
        fovData.HUD.Position = UDim2.new(0.5, 0, -0.12, 0)
        local rollDown = TweenService:Create(fovData.HUD, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(0.5, 0, 0.82, 0)
        })
        rollDown:Play()
        fovData.isHUDVisible = true
    end
    local percent = (CONFIG.FOVRadius - CONFIG.MinFOV) / (CONFIG.MaxFOV - CONFIG.MinFOV)
    fovData.Fill.Size = UDim2.new(percent, 0, 1, 0)
    fovData.Knob.Position = UDim2.new(percent, 0, 0.5, 0)
    fovData.Number.Text = tostring(CONFIG.FOVRadius)
    fovData.hideTimer = task.delay(CONFIG.HUDAutoHideDelay, function()
        local rollUp = TweenService:Create(fovData.HUD, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(0.5, 0, -0.12, 0)
        })
        rollUp:Play()
        fovData.isHUDVisible = false
        task.wait(0.35)
        fovData.HUD.Visible = false
        fovData.hideTimer = nil
    end)
end

local dragging = false
local sliderBG = fovData.SliderBG
local knob = fovData.Knob

sliderBG.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        local percent = (input.Position.X - sliderBG.AbsolutePosition.X) / sliderBG.AbsoluteSize.X
        UpdateSlider(percent)
    end
end)
