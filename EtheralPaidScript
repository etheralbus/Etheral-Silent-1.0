-- Gyro setup
local function SetupGyro()
    local char = Player.Character
    if not char then
        print("No character yet")
        return false
    end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then
        print("No HumanoidRootPart")
        return false
    end
    if gyro then gyro:Destroy() end
    torso = hrp
    gyro = Instance.new("BodyGyro")
    gyro.Parent = torso
    gyro.MaxTorque = Vector3.new(4000, 4000, 4000)
    gyro.D = 50
    gyro.P = 5000
    gyro.CFrame = torso.CFrame
    print("Gyro created successfully")
    return true
end

-- Retry gyro every few seconds if not set
local function EnsureGyro()
    if not gyro or not gyro.Parent then
        SetupGyro()
    end
end

