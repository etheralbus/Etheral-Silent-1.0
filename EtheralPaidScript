--[[
    Modern Silent Aim / Aimbot Template
    - Uses BodyGyro for undetected aiming
    - Includes a toggleable FOV circle
    - Modular structure for easy feature addition
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera

local Player = Players.LocalPlayer
local Mouse = Player:GetMouse()

-- Configuration
local CONFIG = {
    FOVRadius = 90,
    LockStrength = 0.5,
    MaxDistance = 200,
    ToggleKey = Enum.KeyCode.X,
}

-- State
local AimlockEnabled = false
local CurrentTarget = nil
local Gyro = nil
local Torso = nil

-- GUI Setup
local function SetupGUI()
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "AimlockGUI"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.IgnoreGuiInset = true
    ScreenGui.Parent = Player:WaitForChild("PlayerGui")

    -- FOV Circle
    local FovFrame = Instance.new("Frame")
    FovFrame.Size = UDim2.new(0, CONFIG.FOVRadius * 2, 0, CONFIG.FOVRadius * 2)
    FovFrame.Position = UDim2.new(0, 0, 0, 0)
    FovFrame.BackgroundTransparency = 1
    FovFrame.ClipsDescendants = true
    FovFrame.Parent = ScreenGui

    -- Dashes for the FOV circle
    for i = 1, 20 do
        local angle = (i / 20) * 2 * math.pi
        local x = CONFIG.FOVRadius * math.cos(angle)
        local y = CONFIG.FOVRadius * math.sin(angle)
        local dash = Instance.new("Frame")
        dash.Size = UDim2.new(0, 8, 0, 2)
        dash.Position = UDim2.new(0.5, x - 4, 0.5, y - 1)
        dash.BackgroundColor3 = Color3.fromRGB(220, 160, 255)
        dash.BackgroundTransparency = 0
        dash.BorderSizePixel = 0
        dash.Rotation = math.deg(angle)
        dash.Parent = FovFrame
    end

    -- Status Label
    local StatusLabel = Instance.new("TextLabel")
    StatusLabel.Size = UDim2.new(0, 200, 0, 25)
    StatusLabel.Position = UDim2.new(0.5, -100, 1.2, 0)
    StatusLabel.BackgroundTransparency = 1
    StatusLabel.Text = "○ READY"
    StatusLabel.TextColor3 = Color3.fromRGB(180, 120, 210)
    StatusLabel.TextSize = 13
    StatusLabel.Font = Enum.Font.SourceSansBold
    StatusLabel.Parent = FovFrame

    return { ScreenGui = ScreenGui, FovFrame = FovFrame, StatusLabel = StatusLabel }
end

local GUI = SetupGUI()

-- Update status text
local function UpdateStatus(text)
    if GUI.StatusLabel then
        GUI.StatusLabel.Text = text
    end
end

-- BodyGyro Setup
local function SetupGyro()
    local Character = Player.Character
    if not Character then return false end
    local RootPart = Character:FindFirstChild("HumanoidRootPart")
    if not RootPart then return false end
    if Gyro then Gyro:Destroy() end
    Torso = RootPart
    Gyro = Instance.new("BodyGyro")
    Gyro.Parent = Torso
    Gyro.MaxTorque = Vector3.new(4000, 4000, 4000)
    Gyro.D = 50
    Gyro.P = 5000
    Gyro.CFrame = Torso.CFrame
    return true
end

-- Character respawn handling
Player.CharacterAdded:Connect(function()
    task.wait(0.5)
    SetupGyro()
end)

if Player.Character then
    SetupGyro()
end

-- Target acquisition functions
local function IsPlayerDowned(Character)
    if not Character then return true end
    local Humanoid = Character:FindFirstChild("Humanoid")
    if not Humanoid or Humanoid.Health <= 0 then return true end
    local State = Humanoid:GetState()
    return State == Enum.HumanoidStateType.Physics or
           State == Enum.HumanoidStateType.Dead or
           State == Enum.HumanoidStateType.FallingDown or
           State == Enum.HumanoidStateType.GettingUp
end

local function GetTargets(MousePos)
    local Targets = {}
    local CameraPos = Camera.CFrame.Position
    for _, Player in pairs(Players:GetPlayers()) do
        if Player ~= Player then
            local Character = Player.Character
            if Character and not IsPlayerDowned(Character) then
                local Head = Character:FindFirstChild("Head")
                if Head then
                    local HeadPos, OnScreen = Camera:WorldToScreenPoint(Head.Position)
                    if OnScreen then
                        local Distance = (Head.Position - CameraPos).Magnitude
                        if Distance <= CONFIG.MaxDistance then
                            table.insert(Targets, {
                                Player = Player,
                                Head = Head,
                                HeadScreenPos = Vector2.new(HeadPos.X, HeadPos.Y),
                                Distance = Distance,
                                HeadPosition = Head.Position,
                            })
                        end
                    end
                end
            end
        end
    end
    return Targets
end

-- Main loop
RunService.RenderStepped:Connect(function()
    local MouseX, MouseY = Mouse.X, Mouse.Y
    if GUI.FovFrame then
        GUI.FovFrame.Position = UDim2.new(0, MouseX - CONFIG.FOVRadius, 0, MouseY - CONFIG.FOVRadius)
    end

    if not AimlockEnabled or not Gyro or not Torso then
        if AimlockEnabled and not Gyro then
            SetupGyro()
        end
        return
    end

    local Targets = GetTargets(Vector2.new(MouseX, MouseY))
    if #Targets == 0 then
        if CurrentTarget then
            CurrentTarget = nil
            UpdateStatus("○ NO PLAYERS")
        end
        return
    end

    -- Find the closest target
    local BestTarget = nil
    local BestDist = CONFIG.FOVRadius + 1
    for _, Target in pairs(Targets) do
        local Dist = (Target.HeadScreenPos - Vector2.new(MouseX, MouseY)).Magnitude
        if Dist <= CONFIG.FOVRadius and Dist < BestDist then
            BestDist = Dist
            BestTarget = Target
        end
    end

    if BestTarget then
        CurrentTarget = BestTarget
        local LookAt = CFrame.lookAt(Torso.Position, CurrentTarget.HeadPosition)
        Gyro.CFrame = Gyro.CFrame:Lerp(LookAt, CONFIG.LockStrength)
        UpdateStatus("● " .. CurrentTarget.Player.Name .. " (" .. math.floor(CurrentTarget.Distance) .. "s)")
    else
        if CurrentTarget then
            CurrentTarget = nil
            UpdateStatus("○ NO TARGET")
        end
    end
end)

-- Keybind
UserInputService.InputBegan:Connect(function(Input)
    if Input.KeyCode == CONFIG.ToggleKey then
        AimlockEnabled = not AimlockEnabled
        UpdateStatus(AimlockEnabled and "● AIMING" or "○ READY")
        if not AimlockEnabled then
            CurrentTarget = nil
        end
    end
end)
