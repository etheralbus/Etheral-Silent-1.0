-- HUD Timer
local hideTask = nil

local function OpenHUD()
    local hud = fovData.HUD
    if fovData.isHUDVisible then return end
    
    hud.Visible = true
    hud.Position = UDim2.new(0.5, -100, -0.12, 0)
    
    local rollDown = TweenService:Create(hud, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5, -100, 0.05, 0)
    })
    rollDown:Play()
    fovData.isHUDVisible = true
end

local function UpdateHUDNumber(fovSize)
    local sizeLabel = fovData.SizeLabel
    sizeLabel.Text = tostring(fovSize)
end

local function HideHUD()
    if not fovData.isHUDVisible then return end
    
    local hud = fovData.HUD
    
    local rollUp = TweenService:Create(hud, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Position = UDim2.new(0.5, -100, -0.12, 0)
    })
    rollUp:Play()
    fovData.isHUDVisible = false
    
    task.wait(0.35)
    hud.Visible = false
end

local function StartHideTimer()
    if hideTask then
        task.cancel(hideTask)
        hideTask = nil
    end
    
    hideTask = task.delay(CONFIG.HUDAutoHideDelay, function()
        HideHUD()
        hideTask = nil
    end)
end

local function ShowHUD(fovSize)
    if not fovData.isHUDVisible then
        OpenHUD()
    end
    
    UpdateHUDNumber(fovSize)
    StartHideTimer()
end

