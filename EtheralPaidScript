print("DEBUG: Script started")

-- Check basic services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local Camera = Workspace.CurrentCamera

print("DEBUG: Services loaded")

local Player = Players.LocalPlayer
if not Player then
    print("DEBUG: No LocalPlayer found")
    return
end
print("DEBUG: LocalPlayer found: " .. tostring(Player.Name))

-- Wait for PlayerGui
local PlayerGui = Player:WaitForChild("PlayerGui")
print("DEBUG: PlayerGui found")

-- Try to create a simple UI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "TestGUI"
screenGui.Parent = PlayerGui
print("DEBUG: ScreenGui created")

local testFrame = Instance.new("Frame")
testFrame.Size = UDim2.new(0, 100, 0, 100)
testFrame.Position = UDim2.new(0.5, -50, 0.5, -50)
testFrame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
testFrame.BackgroundTransparency = 0
testFrame.Parent = screenGui
print("DEBUG: Red test frame created, should be visible")

local label = Instance.new("TextLabel")
label.Size = UDim2.new(1, 0, 1, 0)
label.BackgroundTransparency = 1
label.Text = "X to toggle"
label.TextColor3 = Color3.fromRGB(255,255,255)
label.TextSize = 24
label.Font = Enum.Font.SourceSansBold
label.Parent = testFrame

print("DEBUG: All done, waiting for X key")

UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.X then
        print("DEBUG: X key pressed")
        if testFrame.BackgroundColor3 == Color3.fromRGB(255,0,0) then
            testFrame.BackgroundColor3 = Color3.fromRGB(0,255,0)
            label.Text = "AIMLOCK ON"
        else
            testFrame.BackgroundColor3 = Color3.fromRGB(255,0,0)
            label.Text = "AIMLOCK OFF"
        end
    end
end)
